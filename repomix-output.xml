                      transition={{ duration: 1.1, delay: 1.15 + index * 0.12, ease: heroEase }}
                      className="font-display block text-[clamp(3.2rem,8vw,7.4rem)] leading-[0.9] tracking-[-0.04em] text-white"
                    >
